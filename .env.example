# Firebase Configuration
# Obtén estos valores en: Firebase Console → Tu Proyecto → Configuración → Tus apps → Web
# Estos valores NO son secretos en el sentido tradicional — son necesarios en el cliente.
# La seguridad real la proveen las Firestore Security Rules.

VITE_FIREBASE_API_KEY=AIzaSy_REEMPLAZA_ESTO
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456
